# Copy this file to .env and fill in the values
# cp .env.example .env

# ── Backend API ───────────────────────────────────────────────
# For local dev, Vite proxies /api → localhost:3001 automatically
# So you can leave VITE_API_BASE_URL empty for local dev
VITE_API_BASE_URL=

# Google OAuth Client ID (from Google Cloud Console)
# Authorized origins must include your Vercel URL and http://localhost:5173
VITE_GOOGLE_CLIENT_ID=

# ── For production, set these: ────────────────────────────────
# VITE_API_BASE_URL=https://your-backend.onrender.com/api/v1
